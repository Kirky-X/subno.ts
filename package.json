{
  "name": "securenotify",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "npx tsx scripts/run-migrations.ts && next dev",
    "build": "npx tsx scripts/run-migrations.ts && next build --webpack",
    "start": "npx tsx scripts/run-migrations.ts && next start",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "add-header": "node scripts/add-license-header.js",
    "pre-check": "node scripts/pre-check.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "npm run add-header",
      "git add"
    ]
  },
  "dependencies": {
    "@types/redis": "^4.0.10",
    "@vercel/kv": "^3.0.0",
    "@vercel/postgres": "^0.10.0",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.1",
    "node-forge": "^1.3.3",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "redis": "^5.10.0",
    "uuid": "^13.0.0",
    "vercel": "^50.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8.57.0",
    "eslint-config-next": "16.1.1",
    "husky": "^9.1.7",
    "k6": "^0.0.0",
    "lint-staged": "^16.2.7",
    "supertest": "^7.1.4",
    "typescript": "^5",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "eslint-config-next": {
      "eslint": "$eslint"
    }
  }
}