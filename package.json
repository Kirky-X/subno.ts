{
  "name": "subno.ts",
  "version": "0.2.1",
  "description": "加密推送通知服务 - SecureNotify",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "vercel-build": "next build",
    "db:migrate": "node scripts/run-migrations.js",
    "db:migrate:revocation": "node scripts/migrate-revocation.js",
    "db:migrate:revocation:rollback": "node scripts/migrate-revocation.js rollback",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "dep:check": "node scripts/dependency-check.js",
    "dep:audit": "npm audit",
    "dep:fix": "npm audit fix",
    "security:check-exports": "node scripts/check-module-exports.js",
    "security:audit": "npm run security:check-exports && echo '✅ 安全审计完成'"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "^0.12.0",
    "async-retry": "^1.3.3",
    "crypto-js": "^4.2.0",
    "drizzle-orm": "^0.45.1",
    "lru-cache": "^11.2.7",
    "mitt": "^3.0.1",
    "next": "^16.1.1",
    "pg": "^8.20.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "rate-limiter-flexible": "^10.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "redis": "^5.10.0",
    "uuid": "^9.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/redis": "^4.0.10",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint-plugin-react": "^7.37.5",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.53.0",
    "vitest": "^4.0.16"
  }
}
