# Database Connection
DATABASE_URL=postgresql://securenotify:securenotify_password@localhost:5435/securenotify
REDIS_URL=redis://localhost:6380

# Message Configuration
PUBLIC_MESSAGE_TTL=43200
PRIVATE_MESSAGE_TTL=86400
PUBLIC_MESSAGE_MAX_COUNT=1000
PRIVATE_MESSAGE_MAX_COUNT=100

# Channel Configuration
TEMPORARY_CHANNEL_TTL=1800              # 30 minutes (seconds)
PERSISTENT_CHANNEL_DEFAULT_TTL=86400    # 24 hours (seconds)
PERSISTENT_CHANNEL_MAX_TTL=604800       # 7 days (seconds)
CHANNEL_CLEANUP_INTERVAL=300            # 5 minutes (seconds)
AUTO_CREATE_CHANNELS_ENABLED=true       # Allow auto-create
MAX_CHANNEL_METADATA_SIZE=2048          # 2KB max metadata

# Security Configuration
MAX_MESSAGE_SIZE=4718592                # 4.5MB
RATE_LIMIT_PUBLISH=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_SUBSCRIBE=5
MAX_PUBLIC_KEY_SIZE=4096                # 4KB max public key

# Key Configuration
KEY_EXPIRY_DEFAULT=604800               # 7 days (seconds)
KEY_EXPIRY_MAX=2592000                  # 30 days (seconds)

# Admin Configuration
ADMIN_MASTER_KEY=your-secret-master-key-change-this-in-production  # Master admin key for creating API keys

# Cleanup Configuration
CLEANUP_BATCH_SIZE=1000
AUDIT_LOG_RETENTION_DAYS=90
MESSAGE_CLEANUP_MAX_AGE_HOURS=12

# Monitoring Configuration
LOG_LEVEL=info
ENABLE_AUDIT_LOG=true

# CORS Configuration
# Default: no cross-origin allowed (empty string)
# Development: CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGINS=